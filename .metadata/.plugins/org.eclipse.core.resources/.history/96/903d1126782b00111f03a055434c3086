static const Ruch seq_wysokosc[] = {
    { GORA, 1000, 100 },
    { DOL,  1000, 100 },
};

static const Ruch seq_obrot[] = {
    { CCW, 10000, 100 },
    { CW,  10000, 100 },
};
/* ▲▲▲ KONIEC SEKCJI DO EDYCJI ▲▲▲ */

Kanal kanal_wysokosc;
Kanal kanal_obrot;
