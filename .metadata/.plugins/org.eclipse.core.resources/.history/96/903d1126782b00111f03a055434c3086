  MX_GPIO_Init();

  /* USER CODE BEGIN 2 */
  kanal_init(&kanal_wysokosc, seq_wysokosc,
             sizeof(seq_wysokosc) / sizeof(seq_wysokosc[0]));

  kanal_init(&kanal_obrot, seq_obrot,
             sizeof(seq_obrot) / sizeof(seq_obrot[0]));
  /* USER CODE END 2 */

  while (1)
  {
    /* USER CODE BEGIN WHILE */
    aktualizuj_kanal(&kanal_wysokosc);
    aktualizuj_kanal(&kanal_obrot);
    /* USER CODE END WHILE */

    /* USER CODE BEGIN 3 */
  }
  /* USER CODE END 3 */
}

