/* USER CODE BEGIN 0 */
void kanal_init(Kanal *k, const Ruch *seq, uint16_t n)
{
    k->sekwencja = seq;
    k->liczba    = n;
    k->krok      = 0;
    k->faza      = 0;
    k->aktywny   = 1;
    k->t_start   = HAL_GetTick();
    HAL_GPIO_WritePin(GPIOA, seq[0].pin, GPIO_PIN_SET);
}

void aktualizuj_kanal(Kanal *k)
{
    if (!k->aktywny) return;

    const Ruch *r = &k->sekwencja[k->krok];
    uint32_t teraz = HAL_GetTick();

    if (k->faza == 0)
    {
        if (teraz - k->t_start >= r->czas_ms)
        {
            HAL_GPIO_WritePin(GPIOA, r->pin, GPIO_PIN_RESET);
            k->t_start = teraz;
            k->faza    = 1;
        }
    }
    else
    {
        if (teraz - k->t_start >= r->przerwa_ms)
        {
            k->krok = (k->krok + 1) % k->liczba;
            HAL_GPIO_WritePin(GPIOA, k->sekwencja[k->krok].pin, GPIO_PIN_SET);
            k->t_start = teraz;
            k->faza    = 0;
        }
    }
}
/* USER CODE END 0 */

